{
  "source": "linear",
  "default_template": "Claude Code",
  "project_paths": {},
  "filters": {
    "assignee": "me",
    "exclude_states": ["done", "canceled"]
  },
  "mapping": {
    "status": {
      "backlog": "backlog",
      "todo": "inbox",
      "unstarted": "inbox",
      "in_progress": "running",
      "started": "running",
      "in_review": "review",
      "done": null,
      "completed": null,
      "canceled": null
    },
    "priority": {
      "urgent": "high",
      "high": "high",
      "medium": "medium",
      "low": "low",
      "no_priority": "none"
    }
  },
  "sync": {
    "default_lane": "inbox",
    "dedupe_by": "source_id",
    "flow_back": true
  }
}
