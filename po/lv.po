msgid "Copy the selected text as HTML to the clipboard."
msgstr "Kopēt atlasīto tekst starpliktuvē kā HTML."

#: src/input/command.zig:165
msgid "Copy URL to Clipboard"
msgstr "Kopēt URL starpliktuvē"

#: src/input/command.zig:166
msgid "Copy the URL under the cursor to the clipboard."
msgstr "Kopēt zem kursora esošo URL starpliktuvē."

#: src/input/command.zig:171
msgid "Copy Terminal Title to Clipboard"
msgstr "Kopēt termināļa virsrakstu starpliktuvē"

#: src/input/command.zig:172
msgid ""
"Copy the terminal title to the clipboard. If the terminal title is not set "
"this has no effect."
msgstr ""
"Kopēt termināļa virsrakstu starpliktuvē. Ja termināļa virsraksts nav "
"iestatīts, šajai darbībai nav efekta."

#: src/input/command.zig:177
msgid "Paste from Clipboard"
msgstr "Ielīmēt no starpliktuves"

#: src/input/command.zig:178
msgid "Paste the contents of the main clipboard."
msgstr "Ielīmēt galvenās starpliktuves saturu."

#: src/input/command.zig:183
msgid "Paste from Selection"
msgstr "Ielīmēt no atlases"

#: src/input/command.zig:184
msgid "Paste the contents of the selection clipboard."
msgstr "Ielīmēt atlases starpliktuves saturu."

#: src/input/command.zig:189
msgid "Start Search"
msgstr "Sākt meklēšanu"

