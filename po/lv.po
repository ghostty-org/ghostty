#: src/input/command.zig:147
msgid "Copy to Clipboard"
msgstr "Kopēt starpliktuvē"

#: src/input/command.zig:148
msgid ""
"Copy the selected text to the clipboard in both plain and styled formats."
msgstr ""
"Kopēt atlasīto tekstu starpliktuvē gan vienkāršā, gan stilizētā formātā."

#: src/input/command.zig:151
msgid "Copy Selection as Plain Text to Clipboard"
msgstr "Kopēt atlasi starpliktuvē kā vienkāršu tekstu"

