#: src/input/command.zig:266
msgid "Scroll the screen up by a page."
msgstr "Ritināt ekrānu vienu lapu augstāk."

#: src/input/command.zig:271
msgid "Scroll Page Down"
msgstr "Ritināt lapu zemāk"

#: src/input/command.zig:272
msgid "Scroll the screen down by a page."
msgstr "Ritināt ekrānu vienu lapu zemāk."

#: src/input/command.zig:278
msgid "Copy Screen to Temporary File and Copy Path"
msgstr "Kopēt ekrānu pagaidu failā un kopēt tā ceļu"

#: src/input/command.zig:279
msgid ""
"Copy the screen contents to a temporary file and copy the path to the "
